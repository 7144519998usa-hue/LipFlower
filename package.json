{
  "name": "lipflower",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "check": "npm run check:internal-links && npm run check:route-coverage && npm run check:programmatic-seo && npm run check:sitemaps && npm run check:structured-data && npm run check:claims && npm run check:metadata && npm run check:security && npm run check:env && npm run check:affiliate && npm run check:a11y",
    "check:a11y": "node --no-warnings scripts/check-a11y.mjs",
    "check:affiliate": "node --no-warnings scripts/check-affiliate.mjs",
    "check:claims": "node --no-warnings scripts/check-claims.mjs",
    "check:env": "node --no-warnings scripts/check-env.mjs",
    "check:internal-links": "node --no-warnings scripts/check-internal-links.mjs",
    "check:metadata": "node --no-warnings scripts/check-metadata.mjs",
    "check:programmatic-seo": "node --no-warnings scripts/check-programmatic-seo.mjs",
    "check:route-coverage": "node --no-warnings scripts/check-route-coverage.mjs",
    "check:security": "node --no-warnings scripts/check-security.mjs",
    "check:sitemaps": "node --no-warnings scripts/check-sitemaps.mjs",
    "check:structured-data": "node --no-warnings scripts/check-structured-data.mjs",
    "verify": "npm run check && npm run build",
    "verify:production": "node --no-warnings scripts/verify-production.mjs",
    "growth:readiness": "node --no-warnings scripts/growth-readiness.mjs",
    "status": "node --no-warnings scripts/site-status.mjs",
    "start": "next start"
  },
  "dependencies": {
    "@vercel/analytics": "^2.0.1",
    "next": "^16.2.4",
    "react": "18.2.0",
    "react-dom": "18.2.0"
  },
  "overrides": {
    "postcss": "^8.5.10"
  }
}
